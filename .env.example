# ==============================================================================
# Weather Monitoring Project — Environment Variables Template
# ==============================================================================
# Copy this file to .secrets/secrets.env and .secrets/secrets-telegram.env
# as required by the Makefile.

# --- Weather App Settings (.secrets/secrets.env) ---

# InfluxDB Configuration
INFLUX_URL=http://influxdb.monitoring.svc:8086
INFLUX_TOKEN=your_influxdb_token_here
INFLUX_ORG=your_org_name
INFLUX_BUCKET=your_bucket_name

# Neocities Hosting Configuration
NEOCITIES_TOKEN=your_neocities_api_key_here
NEOCITIES_URL=https://neocities.org/api/upload
WEBHOST_URL=https://your-site-subdomain.neocities.org

# Application Logic
WAIT_SECONDS=3600
LOOP=true
DEBUG=false

# --- Telegram Proxy Settings (.secrets/secrets-telegram.env) ---

# Telegram Bot Credentials
BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here

# Network Settings
PORT=8080
